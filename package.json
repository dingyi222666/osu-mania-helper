{
    "name": "koishi-plugin-osu-mania-helper",
    "description": "一个提供 osu!mania 工具集的 Koishi 插件，包括谱面难度分析和希腊字母图片生成。",
    "version": "1.2.4",
    "main": "lib/index.cjs",
    "module": "lib/index.mjs",
    "typings": "lib/index.d.ts",
    "types": "lib/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib/index.mjs",
            "require": "./lib/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "type": "module",
    "files": [
        "lib",
        "dist",
        "resources"
    ],
    "license": "MIT",
    "keywords": [
        "chatbot",
        "koishi",
        "plugin",
        "osu",
        "mania"
    ],
    "peerDependencies": {
        "koishi": "^4.18.9",
        "koishi-plugin-puppeteer": "^3.0.0"
    },
    "peerDependenciesMeta": {
        "koishi-plugin-puppeteer": {
            "optional": true
        }
    },
    "dependencies": {
        "@jimp/core": "^1.6.0",
        "jimp": "^1.6.0"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^7.18.1-alpha.3",
        "@typescript-eslint/parser": "^8.45.1-alpha.0",
        "esbuild": "^0.25.10",
        "esbuild-register": "npm:@shigma/esbuild-register@^1.1.1",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.2",
        "eslint-config-standard": "^17.1.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-n": "^16.6.2",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-promise": "^7.2.1",
        "yakumo": "^1.0.0",
        "yakumo-esbuild": "^1.0.0",
        "yakumo-mocha": "^1.0.0",
        "yakumo-tsc": "^1.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "yarn yakumo build",
        "bump": "yarn yakumo version",
        "dep": "yarn yakumo upgrade",
        "pub": "yarn yakumo publish",
        "lint": "yarn eslint src --ext=ts",
        "lint-fix": "yarn eslint src --ext=ts --fix"
    },
    "koishi": {
        "description": {
            "zh": "提供 osu!mania 工具集，包括谱面难度分析和希腊字母图片生成。"
        }
    },
    "bugs": {
        "url": "https://github.com/dingyi222666/koishi-plugin-osu-mania-helper/issues"
    },
    "homepage": "https://github.com/dingyi222666/koishi-plugin-osu-mania-helper#readme",
    "repository": "git@github.com:dingyi222666/osu-mania-helper.git",
    "author": "dingyi222666 <dingyi222666@foxmail.com>"
}
